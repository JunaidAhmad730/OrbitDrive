{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",

    "strict": true,

    "esModuleInterop": true,
    "resolveJsonModule": true,

    "skipLibCheck": true,

    "types": ["node"],

    "outDir": "./dist"
  },

  "include": ["src/**/*", "drizzle.config.ts"],

  "exclude": ["node_modules", "dist"]
}
